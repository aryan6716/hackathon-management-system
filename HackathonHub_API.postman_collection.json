{
  "info": {
    "name": "HackathonHub API",
    "_postman_id": "hackathonhub-collection-v1",
    "description": "Complete API collection for HackathonHub Hackathon Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register - Participant",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Smith\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"participant\"\n}"
            }
          }
        },
        {
          "name": "Register - Judge",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Judge\",\n  \"email\": \"bob@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"judge\"\n}"
            }
          }
        },
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) pm.collectionVariables.set('token', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@hackathonhub.com\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Create Event (Admin)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/events",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Summer Hackathon 2024\",\n  \"description\": \"48-hour coding challenge for all skill levels\",\n  \"start_date\": \"2024-08-01T09:00:00\",\n  \"end_date\": \"2024-08-03T09:00:00\"\n}"
            }
          }
        },
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/events",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/events/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Assign Judge to Event (Admin)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/events/1/assign-judge",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"judge_id\": 2\n}"
            }
          }
        },
        {
          "name": "Get Event Judges",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/events/1/judges",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Teams",
      "item": [
        {
          "name": "Create Team (Participant)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/teams",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"team_name\": \"CodeCrusaders\",\n  \"event_id\": 1\n}"
            }
          }
        },
        {
          "name": "Join Team (Participant)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/teams/join",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"team_code\": \"A3F9B2\"\n}"
            }
          }
        },
        {
          "name": "Get All Teams",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/teams",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get My Team",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/teams/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Team by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/teams/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Submit Project (Participant)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/projects",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"AI Study Assistant\",\n  \"description\": \"A web app using GPT API to help students create study plans, summarize notes, and quiz themselves. Built with React + FastAPI.\",\n  \"github_link\": \"https://github.com/alice/ai-study-assistant\"\n}"
            }
          }
        },
        {
          "name": "Update Project (Participant)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/projects/1",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"AI Study Assistant v2\",\n  \"description\": \"Updated with more features\"\n}"
            }
          }
        },
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Scores",
      "item": [
        {
          "name": "Submit Score (Judge)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/scores",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": 1,\n  \"score\": 8.5,\n  \"feedback\": \"Excellent use of AI/ML. The UI is clean and the idea is original. Could improve on documentation.\"\n}"
            }
          }
        },
        {
          "name": "Get All Scores",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/scores",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Leaderboard (All Events)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/scores/leaderboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Leaderboard (By Event)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/scores/leaderboard?event_id=1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
