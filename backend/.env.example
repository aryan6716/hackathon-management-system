# ============================================================
# HackathonHub Backend - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=hackathonhub

# JWT Secret (change this to a long random string in production)
JWT_SECRET=hackathonhub_super_secret_jwt_key_2024
JWT_EXPIRES_IN=7d
