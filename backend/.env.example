# ==========================
# DATABASE SETTINGS
# Railway uses these prefixed variables implicitly:
# ==========================
DB_HOST=your_railway_host
DB_USER=your_railway_user
DB_PASSWORD=your_railway_password
DB_NAME=your_railway_database
DB_PORT=3306

# Fallbacks (for local dev)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=hackathon_hub
DB_PORT=3306

# ==========================
# SERVER CONFIG
# ==========================
PORT=8000
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d
NODE_ENV=production
